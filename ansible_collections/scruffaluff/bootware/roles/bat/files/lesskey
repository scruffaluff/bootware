# Less pager configuration file.
#
# For more information, visit https://linux.die.net/man/1/lesskey.

j left-scroll
J noaction
^j noaction
^J noaction
\ej left-scroll
\eJ noaction
k forw-line
K forw-line-force
\ek forw-line
\eK forw-line-force
l back-line
L back-line-force
\el back-line
\eL back-line-force
; right-scroll
\e; right-scroll

#env
LESS = --ignore-case
LESSHISTFILE = -
