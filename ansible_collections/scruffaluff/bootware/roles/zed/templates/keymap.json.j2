// Keyboard shortcuts file for Zed editor.
//
// For more information, visit https://zed.dev/docs/key-bindings.

[
  {
    "bindings": {
{% if ansible_facts.system == "Darwin" %}
      "cmd-shift-c": null,
{% endif %}
      "ctrl-:": "pane::ActivateNextItem",
      "ctrl-shift-a": "workspace::ToggleLeftDock",
      "ctrl-shift-d": "debug_panel::ToggleFocus",
      "ctrl-shift-down": "workspace::SwapPaneLeft",
      "ctrl-shift-e": "project_panel::ToggleFocus",
      "ctrl-shift-f": "pane::DeploySearch",
      "ctrl-shift-h": [
        "action::Sequence",
        ["pane::DeploySearch", "search::ToggleReplace"]
      ],
      "ctrl-shift-j": "pane::ActivatePreviousItem",
      "ctrl-shift-k": "workspace::ActivatePreviousPane",
      "ctrl-shift-l": "workspace::ActivateNextPane",
      "ctrl-shift-left": "pane::SwapItemLeft",
      "ctrl-shift-m": "workspace::ToggleZoom",
      "ctrl-shift-n": "workspace::NewFile",
      "ctrl-shift-o": "file_finder::Toggle",
      "ctrl-shift-p": "command_palette::Toggle",
      "ctrl-shift-right": "pane::SwapItemRight",
      "ctrl-shift-t": "terminal_panel::ToggleFocus",
      "ctrl-shift-up": "workspace::SwapPaneRight",
      "ctrl-shift-w": "pane::CloseActiveItem",
      "ctrl-shift-x": "workspace::ToggleBottomDock"
    }
  },
  {
    "bindings": {
      "ctrl-shift-d": "debugger::Start",
    },
    "context": "DebugPanel",
  },
  {
    "bindings": {
      "alt-;": "editor::MoveRight",
      "alt-b": "editor::MoveToPreviousSubwordStart",
      "alt-f": "editor::MoveToNextSubwordEnd",
      "alt-j": "editor::MoveLeft",
      "alt-k": "editor::MoveDown",
      "alt-l": "editor::MoveUp",
      "alt-q": "editor::Rewrap",
      "alt-w": "editor::DeleteToNextWordEnd",
      "{{ zed_ctrl_key }}-q": null,
      "{{ zed_ctrl_key }}-space": null,
      "ctrl-.": "editor::ToggleCodeActions",
      "ctrl-/": ["editor::ToggleComments", { "advance_downwards": false }],
      "ctrl->": "outline::Toggle",
      "ctrl-[": "pane::GoBack",
      "ctrl-\\": "pane::SplitAndMoveRight",
      "ctrl-]": "pane::GoForward",
      "ctrl-a": "editor::MoveToBeginningOfLine",
      "ctrl-down": "editor::AddSelectionBelow",
      "ctrl-e": "editor::MoveToEndOfLine",
      "ctrl-enter": "editor::NewlineBelow",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-h": "buffer_search::DeployReplace",
      "ctrl-i": "editor::ShowCompletions",
      "ctrl-left": "editor::MoveToPreviousSubwordStart",
      "ctrl-right": "editor::MoveToNextSubwordEnd",
      "ctrl-shift-enter": "editor::NewlineAbove",
      "ctrl-shift-s": "terminal_panel::ToggleFocus",
      "ctrl-u": "editor::DeleteToBeginningOfLine",
      "ctrl-up": "editor::AddSelectionAbove",
      "ctrl-w": "editor::DeleteToPreviousWordStart",
      "ctrl-{": "editor::GoToPreviousHunk",
      "ctrl-}": "editor::GoToHunk",
      "shift-left": "editor::MoveToPreviousWordStart",
      "shift-right": "editor::MoveToNextWordEnd",
    },
    "context": "Editor",
  },
  {
    "bindings": {
      "alt-tab": null,
    },
    "context": "Onboarding",
  },
  {
    "bindings": {
      "ctrl-[": "pane::GoBack",
      "ctrl-]": "pane::GoForward",
    },
    "context": "Pane",
  },
  {
    "bindings": {
      "ctrl-n": "project_panel::NewFile",
      "ctrl-shift-n": "project_panel::NewDirectory",
    },
    "context": "ProjectPanel",
  },
  {
    "bindings": {
      "ctrl-.": ["terminal::SendText", "\ue001"],
      "ctrl-/": ["terminal::SendText", "\ue004"],
      "ctrl-;": ["terminal::SendText", "\ue000"],
      "ctrl-[": ["terminal::SendText", "\ue002"],
      "ctrl-\\": ["terminal::SendText", "\ue005"],
      "ctrl-]": ["terminal::SendText", "\ue003"],
      "ctrl-i": ["terminal::SendText", "\ue006"],
      "ctrl-j": ["terminal::SendText", "\ue007"],
      "ctrl-n": ["terminal::SendKeystroke", "ctrl-n"],
      "ctrl-p": ["terminal::SendKeystroke", "ctrl-p"],
      "ctrl-shift-n": "pane::SplitRight",
      "ctrl-shift-s": "terminal_panel::ToggleFocus",
      "ctrl-shift-t": "workspace::NewTerminal",
    },
    "context": "Terminal",
  },
  {
    "bindings": {
      "{{ zed_ctrl_key }}-b": null,
      "{{ zed_ctrl_key }}-j": null,
    },
    "context": "Workspace",
  },
  {
    "bindings": {
      "ctrl-shift-d": "debug_panel::ToggleFocus",
    },
    "context": "!DebugPanel",
  },
  {
    "bindings": {
      "ctrl-shift-t": "terminal_panel::ToggleFocus",
    },
    "context": "!Terminal",
  },
  {
    "bindings": {
      "alt-c": "debugger::Continue",
      "alt-n": "debugger::StepOver",
      "alt-o": "debugger::StepOut",
      "alt-q": "debugger::Stop",
      "alt-r": "debugger::Restart",
      "alt-s": "debugger::StepInto",
    },
    "context": "debugger_stopped",
  }
]
